# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended for this demo)
DATABRICKS_CLUSTER_ID=

# Unity Catalog target — creates {UC_SCHEMA}_bronze, _silver, _gold + a raw_data Volume
UC_CATALOG=your_uc_catalog
UC_SCHEMA=synergy_baseball_demo

# ---------------------------------------------------------------------------
# Synergy Sports Baseball external API — OAuth2 client credentials.
# Get these from your Synergy account rep. NEVER commit real values.
# Locally: put them here. In Databricks: store in a secret scope named `synergy`
# (keys `client_id` / `client_secret`) and leave these blank — get_secret() falls
# back to the scope. Create the scope with:
#   databricks secrets create-scope synergy
#   databricks secrets put-secret synergy client_id
#   databricks secrets put-secret synergy client_secret
# ---------------------------------------------------------------------------
SYNERGY_CLIENT_ID=
SYNERGY_CLIENT_SECRET=

# Optional: override the secret scope name (default: synergy)
SYNERGY_SECRET_SCOPE=synergy

# Game ingest window (01_ingest_synergy_api) — inclusive ISO dates + season.
SYNERGY_START_DATE=2024-04-01
SYNERGY_END_DATE=2024-04-07
SYNERGY_SEASON=2024

# SQL Warehouse ID (required for the dashboard + Genie stubs in 05).
# Find at: SQL Warehouses > your warehouse > Connection details > HTTP path (last segment)
SQL_WAREHOUSE_ID=your_warehouse_id_here
