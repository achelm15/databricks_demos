# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended for this demo).
DATABRICKS_CLUSTER_ID=

# Unity Catalog target. The notebooks create {UC_SCHEMA}_bronze, _silver, _gold and a raw_data Volume.
UC_CATALOG=your_uc_catalog
UC_SCHEMA=synergy_baseball_demo

# Synergy Sports Baseball external API, OAuth2 client credentials. Get these from your Synergy account
# rep. Locally, put them here. In Databricks, store them in a secret scope named `synergy` (keys
# `client_id` / `client_secret`) and leave these blank; get_secret() falls back to the scope. Create it:
#   databricks secrets create-scope synergy
#   databricks secrets put-secret synergy client_id
#   databricks secrets put-secret synergy client_secret
SYNERGY_CLIENT_ID=
SYNERGY_CLIENT_SECRET=

# Ingest window for 01_ingest_synergy_api, inclusive ISO dates. This is the only time scope: dimensions
# (including the ~293k players catalog) are pulled in full, and the date-windowed facts (games, events,
# practice_sessions) are limited to this range. The default is a narrow month so the all-orgs event
# routes stay tractable; widen it to capture more practice (sessions span 2024-2026). The games route's
# season is derived from the start year.
SYNERGY_START_DATE=2024-06-01
SYNERGY_END_DATE=2024-06-30

# Team scope for the team-keyed routes: events (events + subsets, via teamIds) and players_teamhistory.
# Comma-separated team ids (e.g. your club + affiliates). For events this both limits results to your
# teams and lifts the API's 3-month date cap. Blank = events and teamhistory are skipped.
SYNERGY_TEAM_IDS=

# SQL Warehouse ID, required for the Genie space in 06.
# Find it under SQL Warehouses > your warehouse > Connection details > HTTP path (last segment).
SQL_WAREHOUSE_ID=your_warehouse_id_here
