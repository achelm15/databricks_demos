# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.
#
# Only needed if you are NOT using a ~/.databrickscfg profile.
# Databricks Connect will prefer these env vars over the config file if set.

DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-pat-token>
DATABRICKS_CLUSTER_ID=<your-cluster-id>

# Unity Catalog defaults (optional — edit in notebooks as needed)
UC_CATALOG=<your-catalog>
UC_SCHEMA=<your-schema>
