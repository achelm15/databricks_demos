# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended).
DATABRICKS_CLUSTER_ID=

# Unity Catalog target — creates {UC_SCHEMA}_bronze, _silver, _gold
UC_CATALOG=your_uc_catalog
UC_SCHEMA=rostr_music_industry

# rostr.cc credentials. Login is plain `requests` against /v1/auth/rostr —
# no headless browser. Cookie cached at ROSTR_COOKIE_PATH.
ROSTR_USERNAME=you@example.com
ROSTR_PASSWORD=changeme
ROSTR_COOKIE_PATH=.cookie.json

# Path (relative to this directory or absolute) to the seed CSV that lists
# the artists to ingest. Each row is a slug or name. Optional second column
# `rostr_handle` overrides the slugification.
ARTIST_SEED_CSV=artists_seed.csv

# Per-request throttle for the rostr.cc API (seconds). Be a good citizen.
INGEST_RATE_LIMIT=0.5

# Optional roles to ingest besides MANAGEMENT and AGENCY (comma-separated).
# Default keeps it lean: MANAGEMENT,AGENCY,RECORD_LABEL,PUBLISHER
ROSTR_ROLES=MANAGEMENT,AGENCY,RECORD_LABEL,PUBLISHER

# SQL Warehouse ID (only required for 05_create_dashboard.ipynb).
SQL_WAREHOUSE_ID=your_warehouse_id_here
