# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Databricks Connect — leave CLUSTER_ID blank to use Serverless (recommended)
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-pat-token>
DATABRICKS_CLUSTER_ID=

# Unity Catalog targets — schemas {UC_SCHEMA}_bronze / _silver / _quarantine
# will be created automatically.
UC_CATALOG=alexander_booth
UC_SCHEMA=dqx_baseball

# Synthetic data sizing
N_PITCHES=50000
DIRTY_FRACTION=0.12
RANDOM_SEED=42
