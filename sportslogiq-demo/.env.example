# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended for this demo)
DATABRICKS_CLUSTER_ID=

# Unity Catalog target — creates {UC_SCHEMA}_bronze, _silver, _gold
UC_CATALOG=your_uc_catalog
UC_SCHEMA=sportlogiq_demo

# SportLogiq Hockey API credentials (https://api.sportlogiq.com)
SPORTLOGIQ_USERNAME=your_sportlogiq_username
SPORTLOGIQ_PASSWORD=your_sportlogiq_password

# Season in SportLogiq format: 'YYYYYYYY' (e.g. 20232024 for the 2023-24 season)
NHL_SEASON=20232024

# Ingest scope (01_ingest_sportlogiq_api): daily | season | team | date_window
INGEST_MODE=daily

# Optional: competition id (SportLogiq default 1 = NHL). Override for AHL, etc.
NHL_COMPETITION_ID=1

# Optional: scope ingest to a single team_id when INGEST_MODE=team (~82 games).
# Leave blank for league-wide ingest. Find IDs with the get_teams() endpoint.
NHL_TEAM_ID=

# Optional: required when INGEST_MODE=date_window — both inclusive YYYY-MM-DD
NHL_START_DATE=
NHL_END_DATE=

# Optional: concurrent per-game API fan-out in notebook 01 (default 6)
INGEST_WORKERS=6

# Optional: cap player-history sample size in notebook 01 (default 50)
PLAYER_HISTORY_LIMIT=50

# SQL Warehouse ID (required for dashboard + Genie creation in 06/07).
# Find at: SQL Warehouses > your warehouse > Connection details > HTTP path (last segment)
SQL_WAREHOUSE_ID=your_warehouse_id_here

# Optional: catalog tags in 05_catalog_enrichment (defaults shown in notebook)
DOMAIN=hockey_analytics
DATA_OWNER=hockey_analytics_team
