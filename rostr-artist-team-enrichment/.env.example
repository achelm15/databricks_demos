# Copy this to .env and fill in your values. .env is gitignored.

# ---------------------------------------------------------------- Databricks
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute for any UC operations.
DATABRICKS_CLUSTER_ID=

# ---------------------------------------------------------------- rostr.cc
# Login email + password. We POST to /v1/auth/rostr to get a session cookie,
# then call the same JSON API the SPA uses. No headless browser required —
# the Castle/Turnstile fraud check is enforced at the web origin only.
ROSTR_USERNAME=you@example.com
ROSTR_PASSWORD=changeme

# Optional: cache the rack.session cookie to disk so we don't re-login every
# run. In a Databricks job, point this at a Volume path. Set blank to disable.
ROSTR_COOKIE_PATH=.cookie.json

# ---------------------------------------------------------------- Google Sheet
# The sheet to enrich.
GOOGLE_SHEET_ID=1o1AQ63dqIFJ10J87rug4dlxovYOd4PDCxf8028GwKxc
GOOGLE_SHEET_TAB=Sheet1

# Auth strategy:
#   "adc"        — use gcloud Application Default Credentials (local dev).
#   "service"    — use a GCP service-account JSON file (production).
GOOGLE_AUTH_MODE=adc

# Required when GOOGLE_AUTH_MODE=service. Path to the SA key JSON
# (or, in a Databricks job, leave blank and pull from `dbutils.secrets`).
GOOGLE_APPLICATION_CREDENTIALS=

# GCP quota project header — required for some workspaces.
GOOGLE_QUOTA_PROJECT=gcp-sandbox-field-eng

# ---------------------------------------------------------------- Optional UC persistence
# Set to "true" to also land raw rostr API responses in a UC Volume + an
# audit Delta table. Off by default — the demo runs sheet -> sheet without it.
PERSIST_TO_UC=false
UC_CATALOG=alexander_booth
UC_SCHEMA=rostr_artist_enrichment
