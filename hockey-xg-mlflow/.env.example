# Databricks workspace
DATABRICKS_HOST=https://e2-demo-field-eng.cloud.databricks.com
# Token is optional when authenticated via `databricks auth login`
# DATABRICKS_TOKEN=dapixxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Unity Catalog target — all assets land in {UC_CATALOG}.{UC_SCHEMA}
UC_CATALOG=alexander_booth
UC_SCHEMA=hockey_xg_mlflow

# SQL warehouse for any SQL execution outside Connect
SQL_WAREHOUSE_ID=your_warehouse_id_here

# MLflow experiment path (will be created if missing)
MLFLOW_EXPERIMENT_NAME=/Users/your.email@databricks.com/hockey-xg-mlflow

# Serving endpoint name (lowercase, hyphens, must be unique in workspace)
SERVING_ENDPOINT_NAME=hockey-xg-endpoint
