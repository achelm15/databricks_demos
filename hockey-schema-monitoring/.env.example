# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Databricks Connect — leave CLUSTER_ID blank to use Serverless (recommended)
DATABRICKS_HOST=https://<your-workspace>.cloud.databricks.com
DATABRICKS_TOKEN=<your-pat-token>
DATABRICKS_CLUSTER_ID=

# Unity Catalog targets — schemas {UC_SCHEMA}_bronze / _silver will be created
UC_CATALOG=alexander_booth
UC_SCHEMA=hockey_schema_monitoring

# Where Lakehouse Monitoring writes its profile + drift tables
# (leave blank to default to <silver>_monitoring)
MONITORING_SCHEMA=

# Email that DBSQL Alerts + Job alerts should notify
ALERT_EMAIL=alexander.booth@databricks.com

# Synthetic data sizing
N_GAMES=8
EVENTS_PER_GAME=400
RANDOM_SEED=42
