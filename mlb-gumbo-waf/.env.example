# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended for this demo)
DATABRICKS_CLUSTER_ID=

# Unity Catalog target
UC_CATALOG=alexander_booth
UC_SCHEMA=mlb_gumbo_waf

# MLB season + sport (sportId=1 is MLB). Narrow the date window for a faster demo run.
MLB_SEASON=2025
MLB_SPORT_ID=1
# Optional: restrict to a single team (e.g. 116 for Detroit). Leave blank for league-wide.
MLB_TEAM_ID=
# Optional: override the date window. Defaults to opening day through today.
MLB_START_DATE=
MLB_END_DATE=

# SQL Warehouse ID (required for dashboard and Genie space creation)
# Find at: SQL Warehouses > your warehouse > Connection details > HTTP path (last segment)
SQL_WAREHOUSE_ID=your_warehouse_id_here

# WAF tagging — surfaced in system.billing usage and on catalog/schemas/tables
WAF_COST_CENTER=field_engineering
WAF_ENV=demo
WAF_DATA_OWNER=mlb_analytics_team
WAF_REMOVE_AFTER=20281231
