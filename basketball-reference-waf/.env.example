# Copy this to .env and fill in your values. .env is gitignored.

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=dapiXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Leave blank to use Serverless compute (recommended for this demo)
DATABRICKS_CLUSTER_ID=

# SQL Warehouse ID (optional — only needed if you add SQL/dashboard steps)
SQL_WAREHOUSE_ID=

# Unity Catalog target
UC_CATALOG=alexander_booth
UC_SCHEMA=basketball_reference_waf

# NBA seasons to ingest, by SEASON-END year (the 2024-25 season => 2025).
# Comma-separated. Every season except NBA_HOLDOUT_SEASON is used for training.
NBA_SEASONS=2023,2024,2025

# The most recent season is held out for an honest, time-based model evaluation.
NBA_HOLDOUT_SEASON=2025

# Train the model on regular-season games only (playoffs still flow through the medallion
# tables; the gamelog pages label regular vs playoff games for us).
NBA_REGULAR_SEASON_ONLY=true

# Polite scrape throttle. Basketball Reference rate-limits ~20 requests/minute and will
# IP-block you (~1 hour) if you exceed it. 5s => ~12/min, comfortable headroom.
NBA_SCRAPE_THROTTLE_SECONDS=5.0
# Optional: cap teams scraped per season (blank = all 30). Handy for a fast smoke run.
NBA_MAX_TEAMS=

# MLflow experiment (must live under /Users/<you>/...)
MLFLOW_EXPERIMENT_NAME=/Users/your.email@databricks.com/basketball-reference-waf
# Registered model name (created in the _gold schema)
MODEL_NAME=home_win_classifier
